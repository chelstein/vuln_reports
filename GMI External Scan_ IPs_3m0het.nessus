    &lt;link rel=&quot;stylesheet&quot; href=&quot;/dashboard/assets/index-77083d68.css&quot;&gt;
  &lt;/head&gt;
  &lt;body&gt;
    &lt;div id=&quot;app&quot;&gt;
      &lt;div id=&quot;loading-bg&quot;&gt;
        &lt;div class=&quot;loading-logo&quot;&gt;

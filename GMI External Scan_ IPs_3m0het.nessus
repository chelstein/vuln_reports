<plugin_publication_date>2011/10/12</plugin_publication_date>
<plugin_type>remote</plugin_type>
<risk_factor>None</risk_factor>
<script_version>$Revision: 1.3 $</script_version>
<see_also>http://www.ietf.org/rfc/rfc4346.txt</see_also>
<solution>Reorder the certificates in the certificate chain.</solution>

    &lt;script async src=&quot;https://www.googletagmanager.com/gtag/js?id=G-SSBKVF3GMX&quot;&gt;&lt;/script&gt;
    &lt;script&gt;
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag(&apos;js&apos;, new Date());
      // Set default consent to &apos;denied&apos; as a placeholder

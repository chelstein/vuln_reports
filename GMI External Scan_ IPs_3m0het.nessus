                                                    &lt;/td&gt;
                                                    &lt;td align=&quot;left&quot; style=&quot;vertical-align: middle;&quot;&gt;
                                                        &lt;a onclick=&quot;readonlySession_Click()&quot; class=&quot;checkboxLabel&quot;&gt;Read Only&lt;/a&gt;
                                                    &lt;/td&gt;
                                                    &lt;td&gt;

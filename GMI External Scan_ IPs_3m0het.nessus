<ReportItem port="5222" svc_name="jabber" protocol="tcp" severity="0" pluginID="83298" pluginName="SSL Certificate Chain Contains Certificates Expiring Soon" pluginFamily="Misc.">
<description>The remote host has an SSL certificate chain with one or more SSL certificates that are going to expire soon. Failure to renew these certificates before the expiration date may result in denial of service for users.</description>
<fname>ssl_future_expiry_certs.nasl</fname>
<plugin_modification_date>2015/05/08</plugin_modification_date>
<plugin_name>SSL Certificate Chain Contains Certificates Expiring Soon</plugin_name>
<plugin_publication_date>2015/05/08</plugin_publication_date>
<plugin_type>remote</plugin_type>
<risk_factor>None</risk_factor>
